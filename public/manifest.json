{
  "manifest_version": 3,
  "name": "Site Lens",
  "version": "1.0.0",
  "description": "Page analysis, SEO auditing, social previews, and accessibility tools in Chrome DevTools. Copyright © 2026 Mike Wall. All rights reserved.",
  "devtools_page": "src/devtools/devtools.html",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Site Lens",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
